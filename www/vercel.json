{
  "version": 2,
  "builds": [{"src": "**/*", "use": "@vercel/static"}],
  "routes": [
    {"src": "/app-ads.txt", "dest": "/public/app-ads.txt"},
    {"src": "/(.*\\.(js|css|html|png|jpg|jpeg|gif|ico|svg|woff|woff2|mp3|json|txt))", "dest": "/$1"},
    {"src": "/public/(.*)", "dest": "/public/$1"},
    {"src": "/privacy-policy", "dest": "/privacy-policy.html"},
    {"src": "/game", "dest": "/game.html"},
    {"src": "/(.*)", "dest": "/index.html"}
  ]
}
